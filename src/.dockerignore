# Docker构建忽略文件，优化构建速度和镜像体积
# Git相关文件
.git
.gitignore
.github

# 测试相关文件
tests/
pytest.ini
.coverage
coverage.xml

# 临时文件和数据文件
tmp/
data/
storage/
reports/
redundant_backup/
training/
workspace/
*.pyc
__pycache__/
*.log

# 环境配置文件
.env
.env.local
config/config.local.yaml

# 文档类文件
docs/
README.md
CHANGELOG.md
LICENSE
