# OpenClaw 环境变量配置
# 复制此文件为 .env 并填写你的实际值

# ============================================
# 1️⃣ LLM API 配置（必需）
# ============================================

# 选择 LLM 提供商: coze | ark | openai
LLM_PROVIDER=coze

# Coze 配置
COZE_WORKLOAD_IDENTITY_API_KEY=your_coze_api_key_here
COZE_INTEGRATION_MODEL_BASE_URL=https://integration.coze.cn/api/v3
COZE_MODEL=doubao-seed-2-0-pro-260215

# 或者使用 Ark/Volcengine
# ARK_API_KEY=your_ark_api_key_here
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-2-0-pro-260215

# ============================================
# 2️⃣ GitHub 配置（用于 CI/CD 集成）
# ============================================

# GitHub Personal Access Token
# 获取方式: GitHub > Settings > Developer settings > Personal access tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub 仓库信息
GITHUB_OWNER=你的GitHub用户名
GITHUB_REPO=你的仓库名

# ============================================
# 3️⃣ CI/CD 服务器配置（用于自动部署）
# ============================================

# 测试服务器地址（IP 或域名）
TEST_SERVER_HOST=123.456.789.012

# SSH 用户名
TEST_SERVER_USER=root

# ⚠️ 注意: SSH 私钥不放在这里！
# 私钥应该配置在 GitHub Secrets 中
# 详见 docs/SSH_KEY_SETUP.md

# ============================================
# 4️⃣ 镜像仓库配置（可选）
# ============================================

# 阿里云镜像仓库
# DOCKER_REGISTRY=registry.cn-hangzhou.aliyuncs.com
# DOCKER_IMAGE_NAME=你的命名空间/openclaw

# Docker Hub（默认）
# DOCKER_REGISTRY=docker.io
# DOCKER_IMAGE_NAME=你的用户名/openclaw

# ============================================
# 5️⃣ 进化系统配置（可选）
# ============================================

# 启用 CI/CD 自动化
EVOLUTION_CICD_ENABLED=true

# 自动触发 CI/CD
EVOLUTION_CICD_AUTO_TRIGGER=true

# 进化分支名称
EVOLUTION_CICD_BRANCH=evolution

# 自动创建 PR
EVOLUTION_CICD_CREATE_PR=true

# 自动合并（谨慎开启）
EVOLUTION_CICD_AUTO_MERGE=false

# ============================================
# 6️⃣ 安全配置（可选）
# ============================================

# 安全扫描失败时阻止操作
GITHUB_SECURITY_BLOCK_ON_FAILURE=false

# CI/CD 前运行安全扫描
EVOLUTION_CICD_SECURITY_ENABLE_SCAN=true

# ============================================
# 使用说明
# ============================================
# 
# 1. 复制此文件:
#    cp .env.example .env
#
# 2. 编辑 .env 文件，填入你的实际值
#
# 3. 确保 .env 在 .gitignore 中（不要提交到 Git！）
#
# 4. 本地运行时使用:
#    export $(cat .env | grep -v '#' | xargs)
#
# ============================================
